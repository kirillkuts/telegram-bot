# Copy to .env and fill in. In Dokploy, set these in the dashboard instead.

# --- required ---
# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# --- bot config ---
# Allowed Telegram chat_ids (comma-separated). Send /start to the bot to learn yours.
TELEGRAM_ALLOWLIST=241795638
# Working directory the bot runs `claude` in (where your repos are cloned).
PROJECT_DIR=/root/workspace

# --- github ---
# Single Personal Access Token with access to all repos you want cloned/pushed.
GITHUB_TOKEN=
# Repos to clone into PROJECT_DIR on startup. Separated by commas/spaces/newlines.
# Accepts full URLs or owner/repo shorthand.
REPOS=kirillkuts/telegram-bot, kirillkuts/db-learning
# Commit identity used inside the container.
GIT_AUTHOR_NAME=kirillkuts
GIT_AUTHOR_EMAIL=kirill.kuts.dev@gmail.com

# --- host bind-mount paths (override if you logged in as a non-root user) ---
# e.g. if you ran `claude` as `ubuntu`, set CLAUDE_DIR=/home/ubuntu/.claude
CLAUDE_DIR=/root/.claude
OBSIDIAN_DIR=/root/.config/obsidian-headless
VAULTS_DIR=/root/vaults
WORKSPACE_DIR=/root/workspace

# --- watchdog tuning (optional) ---
# WATCHDOG_INTERVAL=120
# WATCHDOG_STRIKE_LIMIT=3
